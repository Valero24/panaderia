NODE_ENV=production
PORT=3000

# Filled by docker-compose in container:
# DATABASE_URL=postgresql://cartagena_user:password@postgres:5432/cartagena_db?schema=public

JWT_SECRET=CHANGE_ME_32_PLUS_CHARACTERS_MINIMUM
CORS_ORIGIN=https://staging.example.com
FRONTEND_URL=https://staging.example.com

ENABLE_REAL_AVAILABILITY=false
ENABLE_REAL_PAYMENTS=false

WOMPI_BASE_URL=https://sandbox.wompi.co
WOMPI_PUBLIC_KEY=pub_stagint_or_sandbox_key
WOMPI_PRIVATE_KEY=prv_stagint_or_sandbox_key
WOMPI_EVENTS_SECRET=event_secret_from_wompi

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=notifications@example.com
MAIL_PASS=CHANGE_ME
MAIL_FROM="Cartagena Concierge <notifications@example.com>"

WHATSAPP_PROVIDER=generic
WHATSAPP_API_URL=https://provider.example.com/messages
WHATSAPP_API_TOKEN=CHANGE_ME
WHATSAPP_FROM_NUMBER=573000000000
ENABLE_WHATSAPP_NOTIFICATIONS=false
WHATSAPP_NOTIFICATION_NUMBERS=573187350654,573246100431

# Legacy Stripe variables. Keep empty unless you deliberately test legacy endpoints.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
