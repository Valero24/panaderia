# Runtime env file used by docker-compose.
# Replace every CHANGE_ME value before exposing this stack to real users.

NODE_ENV=production
PORT=3000

JWT_SECRET=CHANGE_ME_32_PLUS_CHARACTERS_MINIMUM
CORS_ORIGIN=http://localhost:3001
FRONTEND_URL=http://localhost:3001

ENABLE_REAL_AVAILABILITY=false
ENABLE_REAL_PAYMENTS=false

WOMPI_BASE_URL=https://sandbox.wompi.co
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=

MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM="Cartagena Concierge <notifications@example.com>"

WHATSAPP_PROVIDER=generic
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_FROM_NUMBER=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
