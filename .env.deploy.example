# Copy this file to .env on the deployment host.

NODE_ENV=production

POSTGRES_DB=cartagena_db
POSTGRES_USER=cartagena_user
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_PASSWORD
POSTGRES_PORT=5432

BACKEND_PORT=3000
FRONTEND_PORT=3001

# Public API URL used by browser-side frontend code.
# Staging example: https://api-staging.example.com
# Local compose example: http://localhost:3000
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_ENABLE_REAL_AVAILABILITY=false
NEXT_PUBLIC_ENABLE_REAL_PAYMENTS=false

# Kept only while legacy Stripe code exists. Do not use for assisted checkout.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Marketing and analytics
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Public contact/conversion links
NEXT_PUBLIC_WHATSAPP_NUMBER=573000000000
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/cartagenatailoredtravel
NEXT_PUBLIC_TIKTOK_URL=https://www.tiktok.com/@cartagenatailoredtravel
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/cartagenatailoredtravel

# Operational WhatsApp notifications for new assisted requests.
# Keep disabled until a real provider is configured.
ENABLE_WHATSAPP_NOTIFICATIONS=false
WHATSAPP_NOTIFICATION_NUMBERS=573187350654,573246100431
