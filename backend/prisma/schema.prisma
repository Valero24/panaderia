generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  USER
  ADMIN
  ADVISOR
  SUPERADMIN
}

enum BookingType {
  PROPERTY
  EXPERIENCE
  PACKAGE
}

enum ProductFeatureAppliesTo {
  PROPERTY
  EXPERIENCE
  PACKAGE
  ALL
}

enum ProductFeatureCategory {
  AMENITY
  LOCATION_STYLE
  EXPERIENCE_STYLE
  TRAVEL_TYPE
  SERVICE_LEVEL
  INCLUDED
  NOT_INCLUDED
  CONDITION
  OTHER
}

enum MediaType {
  IMAGE
  VIDEO
}

enum MediaOwnerType {
  PROPERTY
  EXPERIENCE
  PACKAGE
  DESTINATION
  BLOG
}

enum MediaProvider {
  DIRECT
  YOUTUBE
  VIMEO
  EXTERNAL
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PropertyStatus {
  DRAFT
  ACTIVE
  FEATURED
  MAINTENANCE
  ARCHIVED
}

enum AvailabilitySource {
  SYSTEM
  ADMIN
  AIRBNB
  STRIPE
}

enum PaymentStatus {
  PENDING
  APPROVED
  PAID
  FAILED
  REFUNDED
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum EmailEntityType {
  PRERESERVATION
  BOOKING
  PAYMENT
  REVIEW
  SYSTEM
}

enum InvoiceStatus {
  GENERATED
  PENDING_PAYMENT
  PAID
  CANCELLED
  FAILED
}

enum InvoicePaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  REFUNDED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
}

enum PreReservationStatus {
  PENDING_ADVISOR
  ASSIGNED
  VALIDATING
  AVAILABLE
  UNAVAILABLE
  PAYMENT_PENDING
  PAID
  CONFIRMED
  CANCELLED
}

enum OperationalNotificationStatus {
  PENDING
  SENT
  FAILED
}

enum TranslationStatus {
  NOT_REQUESTED
  PENDING_TRANSLATION
  TRANSLATING
  COMPLETED
  ERROR
}

enum TranslationJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum TranslationEntityType {
  PROPERTY
  EXPERIENCE
  PACKAGE
  DESTINATION
  BLOG
  BLOG_POST
  EXTRA_SERVICE
  PRODUCT_FEATURE
  PACKAGE_COMPONENT
}

enum BulkImportType {
  PROPERTY
  EXPERIENCE
  PACKAGE
  DESTINATION
  BLOG
}

enum BulkImportStatus {
  DRAFT
  UPLOADED
  VALIDATING
  VALIDATED
  FAILED_VALIDATION
  IMPORTING
  COMPLETED
  PARTIALLY_COMPLETED
  FAILED
  CANCELLED
}

enum LeadSource {
  WEBSITE
  WHATSAPP
  EMAIL
  PHONE
  INSTAGRAM
  FACEBOOK
  REFERRAL
  MANUAL
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  RESERVED
  LOST
  ARCHIVED
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum LeadActivityType {
  CALL
  WHATSAPP
  EMAIL
  NOTE
  FOLLOW_UP
  PROPOSAL
  STATUS_CHANGE
  BOOKING_CREATED
  LOST_REASON
  TASK
}

enum LeadTaskStatus {
  PENDING
  COMPLETED
  CANCELLED
  OVERDUE
}

enum ReminderType {
  IN_APP
  EMAIL
  WHATSAPP_MANUAL
}

enum CrmTemplateChannel {
  WHATSAPP
  EMAIL
  NOTE
}

enum CrmNotificationType {
  CRM_TASK_DUE
  CRM_TASK_OVERDUE
  CRM_LEAD_ASSIGNED
  CRM_LEAD_NO_FOLLOWUP
  CRM_LEAD_URGENT
}

//////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////

model User {
  id            Int       @id @default(autoincrement())
  name          String
  email         String    @unique
  password      String
  phone         String?
  role          Role      @default(USER)
  isActive      Boolean   @default(true)
  deactivatedAt DateTime?
  deletedAt     DateTime?
  deletedById   Int?

  createdAt DateTime @default(now())

  bookings Booking[]
  bulkImportJobs BulkImportJob[]
  assignedLeads Lead[] @relation("LeadAssignedAdvisor")
  leadActivities LeadActivity[]
  leadTasks LeadTask[]
  crmNotifications CrmNotification[]

  preReservationsAssigned PreReservation[] @relation("UserPreReservations")
}

//////////////////////////////////////////////////////
// PROPERTIES
//////////////////////////////////////////////////////

model Property {
  id Int @id @default(autoincrement())

  //////////////////////////////////////////////////////
  // COMMERCIAL
  //////////////////////////////////////////////////////

  title        String
  slug         String @unique
  description  String
  translations Json?
  translationsMeta Json?
  translationStatus TranslationStatus @default(NOT_REQUESTED)
  translationError String?
  translationRequestedAt DateTime?
  translationCompletedAt DateTime?

  city    String
  area    String
  address String?
  icalUrl String?

  //////////////////////////////////////////////////////
  // PRICING
  //////////////////////////////////////////////////////

  pricePerNight Float
  priceCop      Float  @default(0)
  baseCurrency  String @default("COP")

  cleaningFee Float @default(0)
  serviceFee  Float @default(0)
  taxes       Float @default(0)

  //////////////////////////////////////////////////////
  // ADVANCED PRICING
  //////////////////////////////////////////////////////

  basePrice          Float
  twoGuestsIncrease  Float @default(0)
  extraGuestIncrease Float @default(0)

  highSeasonPrice Float?
  lowSeasonPrice  Float?

  //////////////////////////////////////////////////////
  // CAPACITY
  //////////////////////////////////////////////////////

  maxGuests     Int
  maxCapacity   Int
  bedrooms      Int @default(1)
  bathrooms     Int @default(1)
  minimumNights Int @default(1)

  //////////////////////////////////////////////////////
  // RULES
  //////////////////////////////////////////////////////

  allowsPets     Boolean @default(false)
  allowsSmoking  Boolean @default(false)
  allowsEvents   Boolean @default(false)
  allowsChildren Boolean @default(true)

  checkInTime  String?
  checkOutTime String?

  cancellationPolicy String?

  //////////////////////////////////////////////////////
  // STATUS
  //////////////////////////////////////////////////////

  status PropertyStatus @default(DRAFT)

  //////////////////////////////////////////////////////
  // SEO
  //////////////////////////////////////////////////////

  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  seoContent     String?

  nearbyAttractions   String?
  locationDescription String?
  guestRecommendations String?
  faq                 Json?

  //////////////////////////////////////////////////////
  // REVIEW CACHE
  //////////////////////////////////////////////////////

  averageRating      Decimal @default(0) @db.Decimal(3, 2)
  reviewCount        Int     @default(0)
  ratingDistribution Json?

  //////////////////////////////////////////////////////
  // INTERNAL
  //////////////////////////////////////////////////////

  internalNotes String?

  //////////////////////////////////////////////////////
  // GEO
  //////////////////////////////////////////////////////

  latitude  Float?
  longitude Float?

  //////////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////////

  images             PropertyImage[]
  extras             ExtraService[]
  features           PropertyFeature[]
  availabilityBlocks AvailabilityBlock[]
  destinations       DestinationProperty[]

  //////////////////////////////////////////////////////
  // TIMESTAMPS
  //////////////////////////////////////////////////////

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

//////////////////////////////////////////////////////
// PROPERTY FEATURES
//////////////////////////////////////////////////////

model PropertyFeature {
  id Int @id @default(autoincrement())

  name String

  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////
// DYNAMIC PRODUCT FEATURES
//////////////////////////////////////////////////////

model ProductFeature {
  id Int @id @default(autoincrement())

  name         String
  slug         String                  @unique
  description  String?
  translations Json?
  translationStatus TranslationStatus @default(NOT_REQUESTED)
  translationError String?
  translationRequestedAt DateTime?
  translationCompletedAt DateTime?
  icon         String?
  category     ProductFeatureCategory  @default(OTHER)
  appliesTo    ProductFeatureAppliesTo
  active       Boolean                 @default(true)

  assignments ProductFeatureAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([active])
  @@index([appliesTo])
  @@index([category])
}

model ProductFeatureAssignment {
  id Int @id @default(autoincrement())

  featureId Int
  feature   ProductFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  productType BookingType
  productId   Int

  createdAt DateTime @default(now())

  @@unique([featureId, productType, productId])
  @@index([productType, productId])
  @@index([featureId])
}

//////////////////////////////////////////////////////
// PROPERTY IMAGES
//////////////////////////////////////////////////////

model PropertyImage {
  id Int @id @default(autoincrement())

  url         String
  mediaType   MediaType @default(IMAGE)
  title       String?
  description String?
  isPrimary   Boolean   @default(false)
  active      Boolean   @default(true)
  sortOrder   Int?

  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model ContentMedia {
  id Int @id @default(autoincrement())

  ownerType    MediaOwnerType
  ownerId      Int
  type         MediaType      @default(IMAGE)
  url          String
  title        String?
  description  String?
  isMain       Boolean        @default(false)
  sortOrder    Int           @default(0)
  provider     MediaProvider @default(EXTERNAL)
  thumbnailUrl String?
  isActive     Boolean       @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([ownerType, ownerId])
  @@index([ownerType, ownerId, isActive])
  @@index([ownerType, ownerId, isMain])
}

//////////////////////////////////////////////////////
// EXPERIENCES
//////////////////////////////////////////////////////

model Experience {
  id Int @id @default(autoincrement())

  title            String
  slug             String @unique
  shortDescription String
  description      String
  translations     Json?
  translationsMeta Json?
  translationStatus TranslationStatus @default(NOT_REQUESTED)
  translationError String?
  translationRequestedAt DateTime?
  translationCompletedAt DateTime?

  location  String
  duration  String
  maxGuests Int
  basePrice Float
  priceCop  Float  @default(0)
  baseCurrency String @default("COP")
  category  String
  mainImage String?
  active    Boolean @default(true)

  policies        String?
  recommendations String?

  //////////////////////////////////////////////////////
  // SEO
  //////////////////////////////////////////////////////

  seoTitle            String?
  seoDescription      String?
  seoContent          String?
  itinerary           String?
  included            String?
  notIncluded         String?
  meetingPoint        String?
  durationDescription String?
  schedule            String?
  conditions          String?
  faq                 Json?
  experienceCategory  String?

  //////////////////////////////////////////////////////
  // REVIEW CACHE
  //////////////////////////////////////////////////////

  averageRating      Decimal @default(0) @db.Decimal(3, 2)
  reviewCount        Int     @default(0)
  ratingDistribution Json?

  images ExperienceImage[]
  extras ExtraService[]
  destinations DestinationExperience[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model ExperienceImage {
  id Int @id @default(autoincrement())

  url         String
  mediaType   MediaType @default(IMAGE)
  title       String?
  description String?
  isPrimary   Boolean   @default(false)
  active      Boolean   @default(true)
  sortOrder   Int?

  experienceId Int
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// PACKAGES
//////////////////////////////////////////////////////

model Package {
  id Int @id @default(autoincrement())

  title            String
  slug             String @unique
  shortDescription String
  description      String
  translations     Json?
  translationsMeta Json?
  translationStatus TranslationStatus @default(NOT_REQUESTED)
  translationError String?
  translationRequestedAt DateTime?
  translationCompletedAt DateTime?

  duration  String
  location  String
  maxGuests Int
  basePrice Float
  priceCop  Float  @default(0)
  baseCurrency String @default("COP")
  mainImage String?
  category  String
  minPeople Int?
  isFeatured Boolean @default(false)

  includes        String?
  notIncludes     String?
  itinerary       String?
  policies        String?
  recommendations String?
  seoTitle        String?
  seoDescription  String?
  seoContent      String?
  faq             Json?
  active          Boolean @default(true)

  //////////////////////////////////////////////////////
  // REVIEW CACHE
  //////////////////////////////////////////////////////

  averageRating      Decimal @default(0) @db.Decimal(3, 2)
  reviewCount        Int     @default(0)
  ratingDistribution Json?

  images     PackageImage[]
  extras     ExtraService[]
  components PackageComponent[]
  destinations DestinationPackage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([isFeatured])
}

model PackageComponent {
  id Int @id @default(autoincrement())

  title            String
  shortDescription String?
  description      String?
  componentType    String?
  day              Int?
  translations     Json?
  translationStatus TranslationStatus @default(NOT_REQUESTED)
  translationError String?
  translationRequestedAt DateTime?
  translationCompletedAt DateTime?
  includes         String?
  excludes         String?
  conditions       String?
  duration         String?
  location         String?
  recommendations  String?
  priceCop         Float?
  baseCurrency     String  @default("COP")
  sortOrder        Int     @default(0)
  active           Boolean @default(true)

  packageId Int
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([packageId])
  @@index([active])
  @@index([sortOrder])
}

model PackageImage {
  id Int @id @default(autoincrement())

  url         String
  mediaType   MediaType @default(IMAGE)
  title       String?
  description String?
  isPrimary   Boolean   @default(false)
  active      Boolean   @default(true)
  sortOrder   Int?

  packageId Int
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Destination {
  id Int @id @default(autoincrement())

  name             String
  slug             String @unique
  shortDescription String?
  description      String?
  seoTitle         String?
  seoDescription   String?
  seoContent       String?
  faq              Json?
  heroImage        String?
  gallery          Json?
  location         String?
  isActive         Boolean @default(true)
  isFeatured       Boolean @default(false)
  sortOrder        Int     @default(0)
  translations     Json?
  translationsMeta Json?
  translationStatus TranslationStatus @default(NOT_REQUESTED)
  translationError String?
  translationRequestedAt DateTime?
  translationCompletedAt DateTime?

  properties  DestinationProperty[]
  experiences DestinationExperience[]
  packages    DestinationPackage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([isActive])
  @@index([isFeatured])
  @@index([sortOrder])
}

model DestinationProperty {
  id Int @id @default(autoincrement())

  destinationId Int
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  sortOrder  Int     @default(0)
  isFeatured Boolean @default(false)
  createdAt  DateTime @default(now())

  @@unique([destinationId, propertyId])
  @@index([destinationId])
  @@index([propertyId])
  @@index([isFeatured])
  @@index([sortOrder])
}

model DestinationExperience {
  id Int @id @default(autoincrement())

  destinationId Int
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  experienceId Int
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  sortOrder  Int     @default(0)
  isFeatured Boolean @default(false)
  createdAt  DateTime @default(now())

  @@unique([destinationId, experienceId])
  @@index([destinationId])
  @@index([experienceId])
  @@index([isFeatured])
  @@index([sortOrder])
}

model DestinationPackage {
  id Int @id @default(autoincrement())

  destinationId Int
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  packageId Int
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  sortOrder  Int     @default(0)
  isFeatured Boolean @default(false)
  createdAt  DateTime @default(now())

  @@unique([destinationId, packageId])
  @@index([destinationId])
  @@index([packageId])
  @@index([isFeatured])
  @@index([sortOrder])
}

model BlogPost {
  id Int @id @default(autoincrement())

  title          String
  slug           String   @unique
  excerpt        String?
  content        String
  coverImage     String?
  category       String?
  tags           Json?
  seoTitle       String?
  seoDescription String?
  seoKeywords    Json?
  authorName     String?
  relatedDestinationSlugs Json?
  relatedPropertySlugs Json?
  relatedExperienceSlugs Json?
  relatedPackageSlugs Json?
  isPublished    Boolean  @default(false)
  publishedAt    DateTime?
  isFeatured     Boolean  @default(false)
  translations   Json?
  translationsMeta Json?
  translationStatus TranslationStatus @default(NOT_REQUESTED)
  translationError String?
  translationRequestedAt DateTime?
  translationCompletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([isPublished])
  @@index([isFeatured])
  @@index([publishedAt])
  @@index([category])
}

model TranslationJob {
  id Int @id @default(autoincrement())

  entityType TranslationEntityType
  entityId   Int
  status     TranslationJobStatus @default(PENDING)

  sourceLanguage String @default("es")
  targetLanguages Json   @default("[\"en\",\"fr\",\"pt\",\"it\"]")

  fields         Json?
  sourceSnapshot Json
  overwrite      Boolean @default(false)

  error       String?
  attempts    Int @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  finishedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([entityType, entityId])
  @@index([status])
  @@index([createdAt])
}

//////////////////////////////////////////////////////
// EXTRA SERVICES
//////////////////////////////////////////////////////

model ExtraService {
  id Int @id @default(autoincrement())

  name         String
  description  String?
  translations Json?
  translationStatus TranslationStatus @default(NOT_REQUESTED)
  translationError String?
  translationRequestedAt DateTime?
  translationCompletedAt DateTime?
  price        Float
  priceCop     Float  @default(0)
  baseCurrency String @default("COP")
  active       Boolean @default(true)

  propertyId Int?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  experienceId Int?
  experience   Experience? @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  packageId Int?
  package   Package? @relation(fields: [packageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([propertyId])
  @@index([experienceId])
  @@index([packageId])
}

//////////////////////////////////////////////////////
// BOOKINGS
//////////////////////////////////////////////////////

model Booking {
  id              Int     @id @default(autoincrement())
  reservationCode String? @unique

  preReservationId String?         @unique
  preReservation   PreReservation? @relation(fields: [preReservationId], references: [id])

  type        BookingType
  referenceId Int
  productName String?

  checkIn  DateTime
  checkOut DateTime?

  guests   Int  @default(1)
  adults   Int?
  children Int?
  infants  Int?

  totalPrice     Float
  taxesAmount    Float?
  discountAmount Float?
  selectedExtras Json?

  customerName               String?
  customerEmail              String?
  customerPhone              String?
  billingLegalOrganizationType       String?
  billingIdentificationDocumentType  String?
  billingIdentificationNumber        String?
  billingVerificationDigit           String?
  billingCustomerName                String?
  billingEmail                       String?
  billingPhone                       String?
  billingDepartment                  String?
  billingMunicipalityId              String?
  billingMunicipalityName            String?
  billingAddress                     String?
  billingTaxResponsibility           String?
  billingTributeId                   String?
  billingDataAccepted                Boolean @default(false)
  billingIsComplete                  Boolean @default(false)
  advisorId                  Int?
  advisorName                String?
  paymentMethod              String?
  invoicePath                String?
  confirmationEmailSentAt    DateTime?
  confirmationWhatsappSentAt DateTime?
  notificationLastError      String?
  cancellationReason         String?
  cancelledAt                DateTime?
  cancelledById              Int?
  reviewToken                String?   @unique
  reviewTokenExpiresAt       DateTime?
  reviewRequestSentAt        DateTime?
  reviewSubmittedAt          DateTime?
  reviewReminderCount        Int       @default(0)
  lastReviewReminderAt       DateTime?

  status BookingStatus @default(PENDING)

  userId Int
  user   User @relation(fields: [userId], references: [id])

  payments Payment[]
  invoices Invoice[]
  reviews  Review[]
  convertedLead Lead? @relation("LeadConvertedBooking")
  emailLogs EmailLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([type, referenceId])
  @@index([checkIn, checkOut])
  @@index([preReservationId])
  @@index([reviewToken])
}

model Review {
  id Int @id @default(autoincrement())

  bookingId Int @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  targetType BookingType
  targetId   Int

  customerName    String?
  customerEmail   String?
  customerPhone   String?
  customerCountry String?
  rating          Int
  title           String?
  comment         String
  categoryRatings Json?
  status          ReviewStatus @default(PENDING)
  featured        Boolean      @default(false)

  submittedAt DateTime @default(now())
  approvedAt  DateTime?
  approvedById Int?
  approvedByName String?
  rejectedAt  DateTime?
  rejectionReason String?
  moderatedAt DateTime?
  moderatedById Int?

  publicName String?
  source     String @default("POST_SERVICE")
  metadata   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([targetType, targetId])
  @@index([status])
  @@index([featured])
  @@index([submittedAt])
}

//////////////////////////////////////////////////////
// AVAILABILITY
//////////////////////////////////////////////////////

model AvailabilityBlock {
  id Int @id @default(autoincrement())

  type        BookingType
  referenceId Int

  startDate DateTime
  endDate   DateTime

  source AvailabilitySource

  expiresAt DateTime?
  notes     String?

  propertyId Int?
  property   Property? @relation(fields: [propertyId], references: [id])

  createdAt DateTime @default(now())

  @@index([type, referenceId])
  @@index([startDate, endDate])
}

//////////////////////////////////////////////////////
// PRE-RESERVATIONS
//////////////////////////////////////////////////////

model PreReservation {
  id String @id @default(uuid())

  customerName           String
  email                  String
  customerPhone          String?
  customerCountry        String?
  locale                 String @default("es")
  paymentMethodPreferred String?
  specialRequests        String?
  selectedExtras         Json?
  billingLegalOrganizationType       String?
  billingIdentificationDocumentType  String?
  billingIdentificationNumber        String?
  billingVerificationDigit           String?
  billingCustomerName                String?
  billingEmail                       String?
  billingPhone                       String?
  billingDepartment                  String?
  billingMunicipalityId              String?
  billingMunicipalityName            String?
  billingAddress                     String?
  billingTaxResponsibility           String?
  billingTributeId                   String?
  billingDataAccepted                Boolean @default(false)
  billingIsComplete                  Boolean @default(false)

  totalPrice     Float  @default(0)
  totalEstimate  Float?
  discountAmount Float?
  taxesAmount    Float?
  finalTotal     Float?
  baseCurrency      String    @default("COP")
  displayCurrency   String    @default("COP")
  subtotalCop       Float?
  taxCop            Float?
  discountCop       Float?
  totalCop          Float?
  displaySubtotal   Float?
  displayTotal      Float?
  exchangeRate      Float     @default(1)
  exchangeRateSource String   @default("SYSTEM")
  exchangeRateDate  DateTime?
  currencyNote      String?

  checkIn  DateTime?
  checkOut DateTime?
  adults   Int?
  children Int?
  infants  Int?

  status PreReservationStatus @default(PENDING_ADVISOR)

  assignedToId Int?
  assignedTo   User? @relation("UserPreReservations", fields: [assignedToId], references: [id])

  internalNotes          String?
  advisorNotes           String?
  manualAdjustmentAmount Float?
  lastModifiedById       Int?
  reassignmentHistory    Json?
  cancellationReason     String?
  cancelledAt            DateTime?
  cancelledById          Int?
  archiveReason          String?
  archivedAt             DateTime?
  archivedById           Int?

  items                    PreReservationItem[]
  payments                 Payment[]
  booking                  Booking?
  invoices                 Invoice[]
  operationalNotifications OperationalNotification[]
  emailLogs                EmailLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([checkIn, checkOut])
  @@index([archivedAt])
}

//////////////////////////////////////////////////////
// PRE-RESERVATION ITEMS
//////////////////////////////////////////////////////

model PreReservationItem {
  id Int @id @default(autoincrement())

  preReservationId String
  preReservation   PreReservation @relation(fields: [preReservationId], references: [id], onDelete: Cascade)

  type        BookingType
  referenceId Int

  name String?

  unitPrice  Float?
  quantity   Int    @default(1)
  totalPrice Float?

  guests Int     @default(1)
  paid   Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([type, referenceId])
}

//////////////////////////////////////////////////////
// PAYMENTS
//////////////////////////////////////////////////////

model Payment {
  id Int @id @default(autoincrement())

  amount   Float
  amountCop Float @default(0)
  currency String @default("COP")
  displayCurrency String @default("COP")
  displayAmount Float?
  exchangeRate Float @default(1)
  exchangeRateSource String @default("SYSTEM")
  exchangeRateDate DateTime?
  paymentMethod String @default("MANUAL")
  provider String @default("MANUAL")
  paymentProvider String @default("MANUAL")
  providerTransactionId String?
  providerReference String?
  providerStatus String?
  paidAt DateTime?
  rawProviderResponse Json?

  status PaymentStatus @default(PENDING)

  stripePaymentIntentId String? @unique
  wompiReference        String? @unique
  wompiPaymentLinkId    String? @unique
  wompiTransactionId    String? @unique
  paymentLinkUrl        String?

  preReservationId String?
  preReservation   PreReservation? @relation(fields: [preReservationId], references: [id])

  bookingId Int?
  booking   Booking? @relation(fields: [bookingId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([preReservationId])
}

model Invoice {
  id            Int     @id @default(autoincrement())
  invoiceNumber String  @unique

  bookingId Int
  booking   Booking @relation(fields: [bookingId], references: [id])

  preReservationId String?
  preReservation   PreReservation? @relation(fields: [preReservationId], references: [id])

  customerName           String
  customerEmail          String
  customerPhone          String?
  customerIdentification String?

  issueDate          DateTime @default(now())
  dueDate            DateTime?
  paidAt             DateTime?
  cancelledAt        DateTime?
  lastStatusChangeAt DateTime @default(now())

  subtotal  Float
  taxes     Float @default(0)
  discounts Float @default(0)
  total     Float
  currency  String @default("COP")
  subtotalCop Float?
  taxCop Float?
  discountCop Float?
  totalCop Float?
  displayCurrency String @default("COP")
  displayTotal Float?
  exchangeRate Float @default(1)
  exchangeRateSource String @default("SYSTEM")
  exchangeRateDate DateTime?

  status        InvoiceStatus        @default(GENERATED)
  paymentStatus InvoicePaymentStatus @default(UNPAID)

  provider String @default("INTERNAL")
  mode     String @default("demo")
  pdfUrl   String?
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([bookingId])
  @@index([preReservationId])
  @@index([status])
  @@index([paymentStatus])
  @@index([issueDate])
}

model CompanySettings {
  id Int @id @default(1)

  logoUrl       String?
  companyName   String  @default("Cartagena Tailored Travel")
  legalId       String?
  address       String?
  phones        String?
  email         String?
  policies      String?
  invoiceFooter String?
  legalInfo     String?

  businessName                 String  @default("Cartagena Tailored Travel")
  legalName                    String?
  nit                          String?
  phone                        String?
  whatsappNumber               String?
  city                         String  @default("Cartagena")
  country                      String  @default("Colombia")
  websiteUrl                   String?
  instagramUrl                 String?
  facebookUrl                  String?
  tiktokUrl                    String?
  faviconUrl                   String?
  primaryColor                 String  @default("#0D2B52")
  secondaryColor               String  @default("#B48A5A")
  defaultCurrency              String  @default("COP")
  baseCurrency                 String  @default("COP")
  enabledDisplayCurrencies     String[] @default(["COP", "USD", "EUR", "BRL"])
  defaultDisplayCurrency       String  @default("COP")
  exchangeRateMode             String  @default("MANUAL")
  exchangeRateSource           String  @default("MANUAL")
  exchangeRateDate             DateTime?
  currencyConversionEnabled    Boolean @default(true)
  exchangeRatesFromCOP         Json    @default("{\"COP\":1,\"USD\":0.00025,\"EUR\":0.00023,\"BRL\":0.0014}")
  taxRate                      Float   @default(0)
  serviceFeeRate               Float   @default(0)
  footerText                   String?
  invoiceNotes                 String?
  bookingTerms                 String?
  privacyPolicyText            String?
  demoModeEnabled              Boolean @default(true)
  realPaymentsEnabled          Boolean @default(false)
  realAvailabilityEnabled      Boolean @default(false)
  whatsappNotificationsEnabled Boolean @default(false)
  factusEnabled                 Boolean @default(false)
  factusMode                    String  @default("mock")
  factusNumberingRangeId        String?
  factusDefaultDocumentCode     String  @default("01")
  factusDefaultPaymentForm      String?
  factusDefaultPaymentMethodCode String?
  factusDefaultUnitMeasureId    String?
  factusDefaultStandardCodeId   String?
  factusDefaultTributeId        String?
  factusDefaultMunicipalityId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model ExchangeRate {
  id           String   @id @default(cuid())
  fromCurrency String
  toCurrency   String
  rate         Decimal  @db.Decimal(18, 6)
  source       String
  rateDate     DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([fromCurrency, toCurrency, isActive])
  @@index([rateDate])
  @@index([createdAt])
}

model ContactRequest {
  id Int @id @default(autoincrement())

  name         String
  email        String
  whatsapp     String
  subject      String
  message      String
  interestType String

  emailSentAt    DateTime?
  emailLastError String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([interestType])
  @@index([createdAt])
}

model Lead {
  id Int @id @default(autoincrement())

  fullName String?
  email String?
  phone String?
  country String?
  city String?
  preferredLanguage String? @default("es")
  source LeadSource @default(WEBSITE)
  status LeadStatus @default(NEW)
  priority LeadPriority @default(MEDIUM)

  assignedAdvisorId Int?
  assignedAdvisor User? @relation("LeadAssignedAdvisor", fields: [assignedAdvisorId], references: [id])

  interestedProductType BookingType?
  interestedProductId Int?
  travelStartDate DateTime?
  travelEndDate DateTime?
  guests Int?
  budget Decimal? @db.Decimal(12, 2)
  message String?
  notes String?
  nextFollowUpAt DateTime?
  lastContactedAt DateTime?

  convertedBookingId Int? @unique
  convertedBooking Booking? @relation("LeadConvertedBooking", fields: [convertedBookingId], references: [id])

  lostReason String?
  priorityScore Int @default(0)
  healthStatus String? @default("GREEN")
  healthUpdatedAt DateTime?

  activities LeadActivity[]
  tasks LeadTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([source])
  @@index([priority])
  @@index([assignedAdvisorId])
  @@index([email])
  @@index([phone])
  @@index([interestedProductType, interestedProductId])
  @@index([nextFollowUpAt])
  @@index([createdAt])
}

model LeadActivity {
  id Int @id @default(autoincrement())

  leadId Int
  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  type LeadActivityType
  title String
  description String?

  createdById Int?
  createdBy User? @relation(fields: [createdById], references: [id])

  scheduledAt DateTime?
  completedAt DateTime?
  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([type])
  @@index([createdById])
  @@index([scheduledAt])
  @@index([createdAt])
}

model LeadTask {
  id Int @id @default(autoincrement())

  leadId Int
  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  title String
  description String?
  dueAt DateTime?
  status LeadTaskStatus @default(PENDING)
  reminderAt DateTime?
  reminderSentAt DateTime?
  reminderType ReminderType @default(IN_APP)

  assignedToId Int?
  assignedTo User? @relation(fields: [assignedToId], references: [id])

  completedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([assignedToId])
  @@index([status])
  @@index([dueAt])
  @@index([reminderAt])
  @@index([createdAt])
}

model CrmMessageTemplate {
  id Int @id @default(autoincrement())

  name String
  channel CrmTemplateChannel
  content String
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([channel])
  @@index([isActive])
}

model CrmNotification {
  id Int @id @default(autoincrement())

  userId Int
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  type CrmNotificationType
  title String
  message String
  readAt DateTime?
  entityType String?
  entityId String?

  createdAt DateTime @default(now())

  @@index([userId, readAt])
  @@index([type])
  @@index([createdAt])
}

model OperationalNotification {
  id Int @id @default(autoincrement())

  channel   String
  recipient String
  message   String
  status    OperationalNotificationStatus @default(PENDING)

  provider         String?
  error            String?
  preReservationId String?
  preReservation   PreReservation? @relation(fields: [preReservationId], references: [id])

  createdAt DateTime  @default(now())
  sentAt    DateTime?

  @@index([status])
  @@index([preReservationId])
  @@index([createdAt])
}

model EmailLog {
  id Int @id @default(autoincrement())

  to      String
  cc      String?
  bcc     String?
  subject String

  templateKey String
  status      EmailStatus @default(PENDING)
  provider    String      @default("smtp")

  entityType EmailEntityType
  entityId   String

  preReservationId String?
  preReservation   PreReservation? @relation(fields: [preReservationId], references: [id])

  bookingId Int?
  booking   Booking? @relation(fields: [bookingId], references: [id])

  errorMessage String?
  sentAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([templateKey, entityType, entityId])
  @@index([preReservationId])
  @@index([bookingId])
  @@index([status])
  @@index([createdAt])
}

model AuditLog {
  id Int @id @default(autoincrement())

  actorId       Int?
  actorRole     String?
  actorName     String?
  action        String
  entityType    String
  entityId      String
  message       String?
  previousValue Json?
  newValue      Json?
  metadata      Json?
  ip            String?
  userAgent     String?

  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}

model BulkImportJob {
  id Int @id @default(autoincrement())

  type   BulkImportType
  status BulkImportStatus @default(DRAFT)

  originalFileName String
  fileSize Int?
  mimeType String?
  source   String? @default("ADMIN_UPLOAD")

  totalRows   Int @default(0)
  validRows   Int @default(0)
  invalidRows Int @default(0)
  createdRows Int @default(0)
  failedRows  Int @default(0)
  skippedRows Int @default(0)
  warningRows Int @default(0)

  validationSummary Json?
  errorSummary      Json?
  warningSummary    Json?
  previewSummary    Json?
  resultSummary     Json?
  metadata          Json?

  createdById    Int?
  createdBy      User? @relation(fields: [createdById], references: [id])
  createdByEmail String?
  createdByRole  String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  uploadedAt DateTime?
  startedAt DateTime?
  finishedAt DateTime?
  validatedAt DateTime?
  completedAt DateTime?

  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([createdById])
}
