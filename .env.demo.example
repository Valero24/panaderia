# Cartagena Tailored Travel - Demo environment example
# Copy the relevant values into your hosting provider.
# Never commit a real .env file with secrets.

NODE_ENV=production
APP_ENV=demo

# Backend / API
PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/cartagena_demo?schema=public
JWT_SECRET=CHANGE_ME_DEMO_32_PLUS_CHARACTERS
CORS_ORIGIN=https://your-demo-frontend.vercel.app
FRONTEND_URL=https://your-demo-frontend.vercel.app

# Demo operating mode
ENABLE_REAL_PAYMENTS=false
ENABLE_REAL_AVAILABILITY=false
WOMPI_ENABLED=false
FACTUS_ENABLED=false
DIAN_MODE=mock
ENABLE_WHATSAPP_NOTIFICATIONS=false
WHATSAPP_NOTIFICATION_NUMBERS=573187350654,573246100431

# Post-service review requests and reminders
ENABLE_EMAIL_NOTIFICATIONS=false
REVIEW_REMINDERS_ENABLED=false
REVIEW_FIRST_REMINDER_DAYS=3
REVIEW_SECOND_REMINDER_DAYS=7
REVIEW_MAX_REMINDERS=2
REVIEW_SCHEMA_MIN_APPROVED=5

# Wompi disabled for demo. Keep empty unless testing sandbox deliberately.
WOMPI_BASE_URL=
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=

# Factus / DIAN disabled for demo
FACTUS_API_URL=
FACTUS_API_TOKEN=

# Optional mail. Leave empty if demo should not send email.
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM="Cartagena Tailored Travel <demo@example.com>"

# Simulated/manual WhatsApp provider
WHATSAPP_PROVIDER=simulated
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_FROM_NUMBER=

# Frontend public variables
NEXT_PUBLIC_SITE_URL=https://panaderia-psi.vercel.app
NEXT_PUBLIC_API_URL=https://your-demo-api.onrender.com
NEXT_PUBLIC_ENABLE_REAL_PAYMENTS=false
NEXT_PUBLIC_ENABLE_REAL_AVAILABILITY=false
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_WHATSAPP_NUMBER=573187350654
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/cartagenatailoredtravel
NEXT_PUBLIC_TIKTOK_URL=https://www.tiktok.com/@cartagenatailoredtravel
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/cartagenatailoredtravel

# Legacy Stripe compatibility. Keep empty for assisted demo checkout.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
